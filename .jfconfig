{
  "capabilities": [
    "apply",
    "land",
    "sandcastle",
    "submit",
    "suggest"
  ],
  "git_draft_commit": [
      "--not",
      "--remotes=origin/*"
  ],
  "git_command": "git",
  "ule_land_enabled": true,
  "vcs_type": "facebook-ios-sdk-git",
  "project_id": "facebook-ios-sdk",
  "sandcastle_job_specs": [
    {
      "command": "SandcastleUniversalCommand",
      "alias": "test-target-determinator",
      "oncall": "fb_mobile_sdk_community_support",
      "description": "run determinator",
      "priority": 0,
      "scheduleType": "diff",
      "capabilities" : {
        "type": "lego",
        "unicastle_size": "I1_LARGE|I2_LARGE",
        "vcs": "facebook-ios-sdk-git",
      },
      "args": {
        "steps": [
          {
            "name": "build hackbook for simulator",
            "shell": "python3 ci/build_hackbook_simulator_ipa.py",
            "determinator": true,
          },
          {
            "name": "build coffeeshop for simulator",
            "shell": "python3 ci/build_coffeeshop_simulator_ipa.py",
            "determinator": true,
          },
          {
            "name": "run unit tests",
            "shell": "python3 ci/unit_tests.py",
            "determinator": true,
          },
          {
            "name": "dynamic xcframework verification",
            "shell": "python3 ci/xcframework_integration_verification_dynamic.py",
            "determinator": true,
          },
          {
            "name": "static xcframework verification",
            "shell": "python3 ci/xcframework_integration_verification_static.py",
            "determinator": true,
          },
          {
            "name": "xcode integration verification",
            "shell": "python3 ci/xcode_integration_verification.py",
            "determinator": true,
          },
          {
            "name": "xcode analyzer job",
            "shell": "python3 ci/xcode_analyzer.py",
            "determinator": true,
          },
          {
            "name": "xcodebuild warnings",
            "shell": "python3 ci/xcodebuild_warnings.py",
            "determinator": true,
          },
          {
            "name": "spm xcframework integration verification",
            "shell": "python3 ci/xcframeworks_spm_integration_verification.py",
            "determinator": true,
          },
          {
            "name": "swift interface check",
            "shell": "python3 ci/swift_interface_check.py",
            "determinator": true,
          },
          {
            "name": "generated swift interface check",
            "shell": "python3 ci/swift_generated_interface_check.py",
            "determinator": true,
          },
          {
            "name": "update legacy hackbook",
            "shell": "python3 ci/legacy_hackbook.py",
            "determinator": true,
          },
          {
            "name": "Lint Swift files",
            "shell": "python3 ci/swiftlint_check.py",
            "determinator": true,
          },
          {
            "name": "Format Swift files",
            "shell": "python3 ci/swiftformat_check.py",
            "determinator": true,
          }
        ],
      },
    },
  ],
}
