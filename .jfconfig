{
  "capabilities": [
    "apply",
    "land",
    "sandcastle",
    "submit",
    "suggest"
  ],
  "git_draft_commit": [
      "--not",
      "--remotes=origin/*"
  ],
  "git_command": "git",
  "ule_land_enabled": true,
  "vcs_type": "facebook-ios-sdk-git",
  "project_id": "facebook-ios-sdk",
  "sandcastle_job_specs": [
    {
      "command": "SandcastleUniversalCommand",
      "alias": "test-target-determinator",
      "oncall": "platform_sdks",
      "description": "run determinator",
      "priority": 0,
      "scheduleType": "diff",
      "capabilities" : {
        "type": "lego",
        "vcs": "facebook-ios-sdk-git",
      },
      "args": {
        "steps": [
          {
            "name": "build hackbook",
            "shell": "python3 ci/build_hackbook_ipa.py",
            "determinator": true,
          }
        ],
      },
    },
  ],
}
